#Взвешенное интервальное планирование
intervals = [
    (0, 3, 3), 
    (1, 4, 2), 
    (3, 5, 4),  
    (4, 7, 2), 
    (5, 8, 3)    
]

def f(n):
    c = 0
    d = n[0][0] - 1
    for i in n:
        b = []
        b.append(i[0]+i[1])
        if d <= i[0]:
            c += i[2]
            d = i[1]
    return f"максимальный вес = {c}"
f(intervals)
