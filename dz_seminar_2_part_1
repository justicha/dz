def check_stability(hospital, student, matching):
    assigned_to = {}
    for h, s in matching.items():
        assigned_to[s] = h
    
    # Множество всех студентов
    all_students = set(student.keys())
    assigned_students = set(assigned_to.keys())
    unassigned_students = all_students - assigned_students

    # Проверка первого типа неустойчивости
    for h, s in matching.items():
        for better_student in hospital[h]:
            if better_student == s:
                break
            if better_student in unassigned_students:
                return f"Неустойчивость 1 типа: {h} и {better_student}"
    
    # Проверка второго типа неустойчивости
    for h, s in matching.items():
        for better_student in hospital[h]:
            if better_student == s:
                break
            if better_student in assigned_to:
                h2 = assigned_to[better_student]
                if student[better_student].index(h) < student[better_student].index(h2):
                    return f"Неустойчивость 2 типа: {h} и {better_student}"
    
    return "Паросочетание устойчиво"

# Проверка
hospital = {
    'Atlanta': ['Xavier', 'Yolanda', 'Zeus'],
    'Boston': ['Yolanda', 'Xavier', 'Zeus'],
    'Chicago': ['Xavier', 'Yolanda', 'Zeus']
}

student = {
    'Xavier': ['Boston', 'Atlanta', 'Chicago'],
    'Yolanda': ['Atlanta', 'Boston', 'Chicago'],
    'Zeus': ['Atlanta', 'Boston', 'Chicago']
}

matching = {'Atlanta': 'Zeus', 'Boston': 'Yolanda', 'Chicago': 'Xavier'}

print(check_stability(hospital, student, matching))
# Выведет: "Неустойчивость 2 типа: Atlanta и Yolanda"
